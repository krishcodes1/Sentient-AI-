# ╔═══════════════════════════════════════════════════════════════════╗
# ║                 SentientAI — Backend Configuration               ║
# ║                                                                   ║
# ║  SETUP (3 steps):                                                ║
# ║    1. Copy this file:  cp .env.example .env                      ║
# ║    2. Generate your keys (see SECRET_KEY section below)           ║
# ║    3. Add ONE AI API key (see LLM Provider section below)        ║
# ╚═══════════════════════════════════════════════════════════════════╝


# ── Step 1: Security Keys (REQUIRED) ────────────────────────────────
#
# You MUST replace these placeholder values with real keys.
# Run this ONE command in your terminal to generate both keys:
#
#   python3 -c "import secrets, base64, os; print('SECRET_KEY=' + secrets.token_urlsafe(48)); print('ENCRYPTION_KEY=' + base64.urlsafe_b64encode(os.urandom(32)).decode())"
#
# Then copy-paste the two output lines below, replacing the placeholders.
#
# What are these?
#   SECRET_KEY     = Signs your login tokens (like a password for the server)
#   ENCRYPTION_KEY = Encrypts stored API keys in the database
#
SECRET_KEY=REPLACE_ME_run_the_command_above
ENCRYPTION_KEY=REPLACE_ME_run_the_command_above


# ── Step 2: Database (defaults work with Docker) ────────────────────
DATABASE_URL=postgresql+asyncpg://sentientai:sentientai@localhost:5432/sentientai
REDIS_URL=redis://localhost:6379/0


# ── Step 3: Choose Your AI Provider ─────────────────────────────────
#
# Pick ONE provider and fill in its API key. Leave the rest blank.
#
# Provider     | Where to get a key
# -------------|----------------------------------------------------
# anthropic    | https://console.anthropic.com
# openai       | https://platform.openai.com/api-keys
# gemini       | https://aistudio.google.com/apikey
# grok         | https://console.x.ai
# deepseek     | https://platform.deepseek.com
# groq         | https://console.groq.com  (free tier available!)
# mistral      | https://console.mistral.ai
# ollama       | No key needed — runs locally for free
#
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# Fill in ONLY the key for your chosen provider:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Ollama (local AI — no API key needed, just install Ollama)
OLLAMA_BASE_URL=http://localhost:11434


# ── OpenClaw Gateway ──────────────────────────────────────────────
# These are set automatically in Docker. Only change for manual setup.
OPENCLAW_GATEWAY_URL=http://localhost:18789
# URL the browser loads for Control UI (iframe / new tab). In Docker Compose, host maps 18789 → openclaw.
OPENCLAW_GATEWAY_BROWSER_URL=http://127.0.0.1:18789
OPENCLAW_CONFIG_DIR=/openclaw-config


# ── Optional Settings ───────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
RATE_LIMIT_PER_MINUTE=60
TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
