# SentientAI Backend Configuration
# Copy this to .env and fill in required values

# ── Required ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentientai:sentientai@localhost:5432/sentientai

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── LLM Provider ─────────────────────────────────────────────────
# Supported: anthropic | openai | gemini | grok | deepseek | groq | mistral | ollama
# You only need ONE API key — whichever provider you choose.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# API Keys (fill in only the one you're using)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Ollama (free local AI — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Auth ──────────────────────────────────────────────────────────
TOKEN_EXPIRE_MINUTES=60

# ── Environment ───────────────────────────────────────────────────
ENVIRONMENT=development
