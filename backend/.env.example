# SentientAI Backend Configuration
# Copy this to .env and fill in required values

# ── Required ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentientai:sentientai@localhost:5432/sentientai

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── LLM Provider (anthropic | openai | ollama) ───────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Auth ──────────────────────────────────────────────────────────
TOKEN_EXPIRE_MINUTES=60

# ── Environment ───────────────────────────────────────────────────
ENVIRONMENT=development
